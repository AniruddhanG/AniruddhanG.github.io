---
layout: none
---
[
  {% for page in site.pages %}
    {% if page.search == true %}
      {
        "title"    : "{{ page.title | escape }}",
        "url"      : "{{ page.url | relative_url }}",
        "content"  : "{{ page.content | strip_html | strip_newlines | truncate: 5000 | escape }}"
      } {% unless forloop.last %},{% endunless %}
    {% endif %}
  {% endfor %}
]