---
layout: none
---
{
  {% assign first = true %}
  {% for page in site.pages %}
    {% if page.search == true and page.title %}
      {% unless first %},{% endunless %}
      {% assign first = false %}
      "{{ page.url | slugify }}": {
        "title": "{{ page.title | escape }}",
        "excerpt": "{{ page.content | strip_html | strip_newlines | truncate: 200 | escape }}",
        "content": "{{ page.content | strip_html | strip_newlines | escape }}",
        "url": "{{ page.url | relative_url }}"
      }
    {% endif %}
  {% endfor %}
}